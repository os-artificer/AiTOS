# Machine-specific settings for AiTOS.
# One-click setup:
#   ./scripts/install_devenv.sh
# Or copy manually:
#   cp env.rc.example env.rc

# --- Makefile toolchain (env.rc is included by Makefile) ---
# macOS: Apple Clang cannot build bare-metal ELF; use x86_64-elf-* cross tools:
# CC := x86_64-elf-gcc
# LD := x86_64-elf-ld
# OBJCOPY := x86_64-elf-objcopy
#
# Linux: native gcc/ld work; leave commented to use Makefile defaults.

# --- Shell script overrides (sourced by scripts/debug*.sh) ---
# export QEMU=qemu-system-x86_64
# export GDB=gdb
# export GDB_PORT=1234
# export QEMU_GUI=1    # 1 = QEMU 窗口 (VGA+PS/2)；0 = 无头串口 (-nographic / pty)
