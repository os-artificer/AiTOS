# Build outputs (Makefile: BUILD_DIR / BIN_DIR)
/build/
/bin/
*.o
*.d
*.elf
*.bin
*.img
*.a
*.map
*.lst

# Local machine config (template: env.rc.example)
/env.rc

# QEMU / GDB runtime (scripts/debug-*.sh)
/bin/qemu-debug.pid
/bin/qemu-serial.log

# Cursor session artifacts
/.cursor/

# Debug and crash dumps
core
core.*
vgcore.*
.gdb_history
*.log

# Editor / OS junk
*~
*.swp
.DS_Store
.idea/

# Personal IDE settings (launch.json / tasks.json remain tracked)
.vscode/settings.json
