# AiTOS GDB init — generated into build/gdb/aitos.gdb
set architecture i386:x86-64
set disassembly-flavor intel
set breakpoint pending on
set mi-async off
set remote interrupt-on-connect on
set confirm off
handle SIGTRAP stop print nopass

define enter-kernel
  jump *@KERNEL_ENTRY@
end

# target remote is injected by the caller.
